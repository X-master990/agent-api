RUNTIME__ENVIRONMENT=development
RUNTIME__BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8001"]
RUNTIME__ALLOWED_HOSTS=["localhost", "127.0.0.1", "testserver"]

DATABASE__HOSTNAME=localhost
DATABASE__USERNAME=postgres
DATABASE__PASSWORD=postgres
DATABASE__PORT=5432
DATABASE__DB=trustmesh

CRYPTO__ISSUER=trustmesh.dev
CRYPTO__PRIVATE_KEY_ENCRYPTION_SECRET=trustmesh-dev-private-key-secret-change-me

PROMETHEUS__ENABLED=true
PROMETHEUS__ADDR=127.0.0.1
